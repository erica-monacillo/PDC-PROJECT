# Database Configuration
# For SQLite (recommended for quick start):
DATABASE_URL=sqlite:./sweets.db

# For PostgreSQL (uncomment and configure if you install PostgreSQL):
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=sweets_db
# DB_USER=postgres
# DB_PASSWORD=your_password

# JWT Secret (change this in production)
JWT_SECRET=your-secret-key-change-in-production